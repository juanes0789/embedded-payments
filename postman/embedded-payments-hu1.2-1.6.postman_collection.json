    {
      "name": "HU 1.6 - Consultar Detalles de Comercio",
      "item": [
        {
          "name": "1.6.1 GET - Consultar detalles (Como ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('Status code es 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Contiene id del comercio', function() {",
                  "    pm.expect(jsonData.id).to.exist;",
                  "});",
                  "pm.test('Admin ve datos bancarios', function() {",
                  "    pm.expect(jsonData.bank_account_data).to.exist;",
                  "});",
                  "pm.test('Contiene email de contacto sin enmascarar (admin)', function() {",
                  "    pm.expect(jsonData.contact_email).to.include('@');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
