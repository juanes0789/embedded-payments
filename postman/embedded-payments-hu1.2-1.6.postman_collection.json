  "item": [
    {
      "name": "0. SETUP - Registrar Comercio (HU 1.1)",
      "item": [
        {
          "name": "1.1 POST - Registrar nuevo comercio",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('merchantId', jsonData.id);",
                  "pm.test('Status code es 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Respuesta tiene id de comercio', function() {",
                  "    pm.expect(jsonData.id).to.exist;",
                  "});",
                  "pm.test('Estado inicial es INACTIVE', function() {",
                  "    pm.expect(jsonData.status).to.equal('INACTIVE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{merchantName}}\",\n  \"email\": \"{{merchantEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/merchants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "merchants"]
            },
            "description": "Registra un nuevo comercio. Este es el primer paso antes de cualquier otra operación."
          }
        }
      ]
    },
