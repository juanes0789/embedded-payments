{
  "info": {
    "_postman_id": "f2f20eb2-2b45-4f40-9670-a5b0d7d9ff12",
    "name": "Embedded Payments - Sprint 1",
    "description": "Coleccion para interactuar con el backend sin frontend. Incluye HU 1.1 y flujo basico de pagos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "merchantName",
      "value": "Zara Demo"
    },
    {
      "key": "merchantEmail",
      "value": "zara.demo+1@test.com"
    }
  ],
  "item": [
    {
      "name": "HU 1.1 - Registro de comercios",
      "item": [
        {
          "name": "Registro exitoso (self registration)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{merchantName}}\",\n  \"email\": \"{{merchantEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "merchants"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var body = pm.response.json();",
                  "pm.test('Estado inicial INACTIVE', function () { pm.expect(body.status).to.eql('INACTIVE'); });",
                  "if (body.id) { pm.collectionVariables.set('merchantId', body.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Registro duplicado (409)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{merchantName}}\",\n  \"email\": \"{{merchantEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "merchants"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 409', function () { pm.response.to.have.status(409); });",
                  "var body = pm.response.json();",
                  "pm.test('Error de duplicado', function () { pm.expect(body.errorCode).to.eql('MERCHANT_ALREADY_EXISTS'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Registro invalido (400)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"email-invalido\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "merchants"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
                  "var body = pm.response.json();",
                  "pm.test('Error de validacion', function () { pm.expect(body.errorCode).to.eql('VALIDATION_ERROR'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Generar token de comercio",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "if (body.token) { pm.collectionVariables.set('jwtToken', body.token); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Payments Flow (opcional demo)",
      "item": [
        {
          "name": "Crear payment intent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"amount\": 10000.00,\n  \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/intents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "intents"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('paymentIntentId', body.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Crear transaccion",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentIntentId\": \"{{paymentIntentId}}\",\n  \"amount\": 10000.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('transactionId', body.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Crear refund",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\",\n  \"amount\": 5000.00,\n  \"reason\": \"customer request\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/refunds",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "refunds"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}

