{
  "info": {
    "_postman_id": "f2f20eb2-2b45-4f40-9670-a5b0d7d9ff12",
    "name": "Embedded Payments - Demo Backend Actual",
    "description": "Coleccion alineada con el backend actual (Spring Boot). Flujo demo real: merchant -> token -> payment intent -> transaction -> refund.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8085"
    },
    {
      "key": "merchantName",
      "value": "Zara Demo"
    },
    {
      "key": "merchantEmail",
      "value": "zara.demo@test.com"
    },
    {
      "key": "amount",
      "value": "10000.00"
    },
    {
      "key": "currency",
      "value": "USD"
    },
    {
      "key": "refundAmount",
      "value": "5000.00"
    },
    {
      "key": "refundReason",
      "value": "customer request"
    }
  ],
  "item": [
    {
      "name": "01 - Registro de comercio",
      "item": [
        {
          "name": "Registro exitoso (self registration)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var suffix = Date.now();",
                  "pm.environment.set('merchantName', 'Zara Demo ' + suffix);",
                  "pm.environment.set('merchantEmail', 'zara.demo+' + suffix + '@test.com');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var body = pm.response.json();",
                  "pm.test('Retorna id', function () { pm.expect(body.id).to.be.a('string').and.not.empty; });",
                  "pm.test('Estado inicial INACTIVE', function () { pm.expect(body.status).to.eql('INACTIVE'); });",
                  "pm.environment.set('merchantId', body.id);",
                  "pm.collectionVariables.set('merchantId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{merchantName}}\",\n  \"email\": \"{{merchantEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "merchants"
              ]
            }
          }
        },
        {
          "name": "Registro duplicado (409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 409', function () { pm.response.to.have.status(409); });",
                  "var body = pm.response.json();",
                  "pm.test('Error code MERCHANT_ALREADY_EXISTS', function () { pm.expect(body.errorCode).to.eql('MERCHANT_ALREADY_EXISTS'); });",
                  "pm.test('Formato de error con traceId', function () { pm.expect(body.traceId).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{merchantName}}\",\n  \"email\": \"{{merchantEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "merchants"
              ]
            }
          }
        },
        {
          "name": "Registro invalido (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
                  "var body = pm.response.json();",
                  "pm.test('Error code VALIDATION_ERROR', function () { pm.expect(body.errorCode).to.eql('VALIDATION_ERROR'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"email\": \"email-invalido\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/merchants",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "merchants"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02 - Auth",
      "item": [
        {
          "name": "Generar token de comercio",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Retorna token', function () { pm.expect(body.token).to.be.a('string').and.not.empty; });",
                  "pm.test('Retorna expiresAt', function () { pm.expect(body.expiresAt).to.be.a('string').and.not.empty; });",
                  "pm.environment.set('jwtToken', body.token);",
                  "pm.collectionVariables.set('jwtToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        },
        {
          "name": "Generar token invalido (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
                  "var body = pm.response.json();",
                  "pm.test('Error code VALIDATION_ERROR', function () { pm.expect(body.errorCode).to.eql('VALIDATION_ERROR'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "03 - Payments",
      "item": [
        {
          "name": "Crear payment intent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var body = pm.response.json();",
                  "pm.test('Estado CREATED', function () { pm.expect(body.status).to.eql('CREATED'); });",
                  "pm.test('Moneda normalizada', function () { pm.expect(body.currency).to.eql('USD'); });",
                  "pm.environment.set('paymentIntentId', body.id);",
                  "pm.collectionVariables.set('paymentIntentId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"amount\": {{amount}},\n  \"currency\": \"{{currency}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/intents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "payments",
                "intents"
              ]
            }
          }
        },
