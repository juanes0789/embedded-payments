              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"amount\": 0,\n  \"currency\": \"US\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/intents",
              "host": [
