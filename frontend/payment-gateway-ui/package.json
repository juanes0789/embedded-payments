    "date-fns": "^2.30.0",
    "uuid": "^9.0.0",
    "dompurify": "^3.0.6",
    "chart.js": "^4.4.0",
    "vue-chartjs": "^5.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.4.0",
    "@vue/test-utils": "^2.4.1",
    "@vitest/ui": "^0.33.0",
    "typescript": "^5.1.6",
    "vue-tsc": "^1.8.9",
